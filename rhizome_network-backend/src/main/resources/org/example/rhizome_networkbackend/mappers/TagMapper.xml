<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.rhizome_networkbackend.mappers.TagMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="org.example.rhizome_networkbackend.entity.po.Tag">
		<!---->
		<id column="tag_id" property="tagId"  />
		<!--标签名-->
		<result column="tag_name" property="tagName"  />
		<!--使用次数-->
		<result column="use_count" property="useCount"  />
		<!---->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 t.tag_id,t.tag_name,t.use_count,t.create_time
	</sql>

	<sql id="base_condition_filed">
			<if test="query.tagId != null">
				 and  t.tag_id = #{query.tagId}
			</if>
			<if test="query.tagName != null and query.tagName!=''">
				 and  t.tag_name = #{query.tagName}
			</if>
			<if test="query.useCount != null">
				 and  t.use_count = #{query.useCount}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  t.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.tagNameFuzzy!= null  and query.tagNameFuzzy!=''">
				 and  t.tag_name like concat('%', #{query.tagNameFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  t.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  t.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM tag t <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM tag t <include refid="query_condition" />
	</select>

	<!-- 插入 （匹配有值的字段）-->
	<insert id="insert" parameterType="org.example.rhizome_networkbackend.entity.po.Tag">
		<selectKey keyProperty="bean.tagId" resultType="Long" order="AFTER">
			SELECT LAST_INSERT_ID()
		</selectKey>
		 INSERT INTO tag
		 <trim prefix="(" suffix=")" suffixOverrides="," >
			<if test="bean.tagName != null">
				 tag_name,
			</if>
			<if test="bean.useCount != null">
				 use_count,
			</if>
			<if test="bean.createTime != null">
				 create_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.tagName!=null">
				 #{bean.tagName},
			</if>
			<if test="bean.useCount!=null">
				 #{bean.useCount},
			</if>
			<if test="bean.createTime!=null">
				 #{bean.createTime},
			</if>
		 </trim>
	</insert>

	<!-- 插入或者更新 （匹配有值的字段）-->
	<insert id="insertOrUpdate" parameterType="org.example.rhizome_networkbackend.entity.po.Tag">
		 INSERT INTO tag
		 <trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.tagId != null">
				 tag_id,
			</if>
			<if test="bean.tagName != null">
				 tag_name,
			</if>
			<if test="bean.useCount != null">
				 use_count,
			</if>
			<if test="bean.createTime != null">
				 create_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.tagId!=null">
				 #{bean.tagId},
			</if>
			<if test="bean.tagName!=null">
				 #{bean.tagName},
			</if>
			<if test="bean.useCount!=null">
				 #{bean.useCount},
			</if>
			<if test="bean.createTime!=null">
				 #{bean.createTime},
			</if>
		 </trim>
		 on DUPLICATE key update 
		 <trim prefix="" suffix="" suffixOverrides=",">
			<if test="bean.tagName!=null">
				 tag_name = VALUES(tag_name),
			</if>
			<if test="bean.useCount!=null">
				 use_count = VALUES(use_count),
			</if>
			<if test="bean.createTime!=null">
				 create_time = VALUES(create_time),
			</if>
		 </trim>
	</insert>

	<!-- 添加 （批量插入）-->
	<insert id="insertBatch" parameterType="org.example.rhizome_networkbackend.entity.po.Tag" useGeneratedKeys="true" keyProperty="tagId">
		 INSERT INTO tag(
			 tag_name,
			 use_count,
			 create_time
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.tagName},
				 #{item.useCount},
				 #{item.createTime}
			 )
		 </foreach>
	</insert>

	<!-- 批量新增修改 （批量插入）-->
	<insert id="insertOrUpdateBatch" parameterType="org.example.rhizome_networkbackend.entity.po.Tag">
		 INSERT INTO tag(
			 tag_name,
			 use_count,
			 create_time
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.tagName},
				 #{item.useCount},
				 #{item.createTime}
			 )
		 </foreach>
			on DUPLICATE key update 
			tag_name = VALUES(tag_name),
			use_count = VALUES(use_count),
			create_time = VALUES(create_time)
	</insert>

	<!--多条件修改-->
	<update id="updateByParam" parameterType="org.example.rhizome_networkbackend.entity.query.TagQuery">
		 UPDATE tag t
 		 <set> 
			<if test="bean.tagName != null">
				 tag_name = #{bean.tagName},
			</if>
			<if test="bean.useCount != null">
				 use_count = #{bean.useCount},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 <include refid="query_condition" />
	</update>

	<!--多条件删除-->
	<delete id="deleteByParam">
		 delete t from tag t
 		 <include refid="query_condition" />
	</delete>

	<!-- 根据TagId修改-->
	<update id="updateByTagId" parameterType="org.example.rhizome_networkbackend.entity.po.Tag">
		 UPDATE tag
 		 <set> 
			<if test="bean.tagName != null">
				 tag_name = #{bean.tagName},
			</if>
			<if test="bean.useCount != null">
				 use_count = #{bean.useCount},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 where tag_id=#{tagId}
	</update>

	<!-- 根据TagId删除-->
	<delete id="deleteByTagId">
		delete from tag where tag_id=#{tagId}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectByTagId" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from tag t where tag_id=#{tagId}
	</select>

	<!-- 根据TagName修改-->
	<update id="updateByTagName" parameterType="org.example.rhizome_networkbackend.entity.po.Tag">
		 UPDATE tag
 		 <set> 
			<if test="bean.useCount != null">
				 use_count = #{bean.useCount},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 where tag_name=#{tagName}
	</update>

	<!-- 根据TagName删除-->
	<delete id="deleteByTagName">
		delete from tag where tag_name=#{tagName}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectByTagName" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from tag t where tag_name=#{tagName}
	</select>

</mapper>