			</if>
			<if test="bean.content != null">
				 content = #{bean.content},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 <include refid="query_condition" />
	</update>

	<!--多条件删除-->
	<delete id="deleteByParam">
		 delete m from moment m
 		 <include refid="query_condition" />
	</delete>

	<!-- 根据MomentId修改-->
	<update id="updateByMomentId" parameterType="org.example.rhizome_networkbackend.entity.po.Moment">
		 UPDATE moment
 		 <set> 
			<if test="bean.userId != null">
				 user_id = #{bean.userId},
			</if>
			<if test="bean.actionType != null">
				 action_type = #{bean.actionType},
			</if>
			<if test="bean.songkey != null">
				 songKey = #{bean.songkey},
			</if>
			<if test="bean.playlistId != null">
