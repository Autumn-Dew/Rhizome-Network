<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.rhizome_networkbackend.mappers.MomentMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="org.example.rhizome_networkbackend.entity.po.Moment">
		<!---->
		<id column="moment_id" property="momentId"  />
		<!---->
		<result column="user_id" property="userId"  />
		<!--1播放 2评论 3创建歌单 4收藏-->
		<result column="action_type" property="actionType"  />
		<!---->
		<result column="songKey" property="songkey"  />
		<!---->
		<result column="playlist_id" property="playlistId"  />
		<!--动态内容-->
		<result column="content" property="content"  />
		<!---->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 m.moment_id,m.user_id,m.action_type,m.songKey,m.playlist_id,
		 m.content,m.create_time
	</sql>

	<sql id="base_condition_filed">
			<if test="query.momentId != null">
				 and  m.moment_id = #{query.momentId}
			</if>
			<if test="query.userId != null">
				 and  m.user_id = #{query.userId}
			</if>
			<if test="query.actionType != null">
				 and  m.action_type = #{query.actionType}
			</if>
			<if test="query.songkey != null and query.songkey!=''">
				 and  m.songKey = #{query.songkey}
			</if>
			<if test="query.playlistId != null">
				 and  m.playlist_id = #{query.playlistId}
			</if>
			<if test="query.content != null and query.content!=''">
				 and  m.content = #{query.content}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  m.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.songkeyFuzzy!= null  and query.songkeyFuzzy!=''">
				 and  m.songKey like concat('%', #{query.songkeyFuzzy}, '%')
			</if>
			<if test="query.contentFuzzy!= null  and query.contentFuzzy!=''">
				 and  m.content like concat('%', #{query.contentFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  m.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  m.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM moment m <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM moment m <include refid="query_condition" />
	</select>

	<!-- 插入 （匹配有值的字段）-->
	<insert id="insert" parameterType="org.example.rhizome_networkbackend.entity.po.Moment">
		<selectKey keyProperty="bean.momentId" resultType="Long" order="AFTER">
			SELECT LAST_INSERT_ID()
		</selectKey>
		 INSERT INTO moment
		 <trim prefix="(" suffix=")" suffixOverrides="," >
			<if test="bean.userId != null">
				 user_id,
			</if>
			<if test="bean.actionType != null">
				 action_type,
			</if>
			<if test="bean.songkey != null">
				 songKey,
			</if>
			<if test="bean.playlistId != null">
				 playlist_id,
			</if>
			<if test="bean.content != null">
				 content,
			</if>
			<if test="bean.createTime != null">
				 create_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.userId!=null">
				 #{bean.userId},
			</if>
			<if test="bean.actionType!=null">
				 #{bean.actionType},
			</if>
			<if test="bean.songkey!=null">
				 #{bean.songkey},
			</if>
			<if test="bean.playlistId!=null">
				 #{bean.playlistId},
			</if>
			<if test="bean.content!=null">
				 #{bean.content},
			</if>
			<if test="bean.createTime!=null">
				 #{bean.createTime},
			</if>
		 </trim>
	</insert>

	<!-- 插入或者更新 （匹配有值的字段）-->
	<insert id="insertOrUpdate" parameterType="org.example.rhizome_networkbackend.entity.po.Moment">
		 INSERT INTO moment
		 <trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.momentId != null">
				 moment_id,
			</if>
			<if test="bean.userId != null">
				 user_id,
			</if>
			<if test="bean.actionType != null">
				 action_type,
			</if>
			<if test="bean.songkey != null">
				 songKey,
			</if>
			<if test="bean.playlistId != null">
				 playlist_id,
			</if>
			<if test="bean.content != null">
				 content,
			</if>
			<if test="bean.createTime != null">
				 create_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.momentId!=null">
				 #{bean.momentId},
			</if>
			<if test="bean.userId!=null">
				 #{bean.userId},
			</if>
			<if test="bean.actionType!=null">
				 #{bean.actionType},
			</if>
			<if test="bean.songkey!=null">
				 #{bean.songkey},
			</if>
			<if test="bean.playlistId!=null">
