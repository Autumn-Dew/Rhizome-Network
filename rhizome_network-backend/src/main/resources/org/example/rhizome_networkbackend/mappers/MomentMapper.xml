			</if>
			<if test="bean.createTime!=null">
				 create_time = VALUES(create_time),
			</if>
		 </trim>
	</insert>

	<!-- 添加 （批量插入）-->
	<insert id="insertBatch" parameterType="org.example.rhizome_networkbackend.entity.po.Moment" useGeneratedKeys="true" keyProperty="momentId">
		 INSERT INTO moment(
			 user_id,
			 action_type,
			 songKey,
			 playlist_id,
			 content,
			 create_time
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.userId},
				 #{item.actionType},
				 #{item.songkey},
				 #{item.playlistId},
				 #{item.content},
				 #{item.createTime}
			 )
		 </foreach>
	</insert>

