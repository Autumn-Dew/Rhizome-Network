				 #{item.createTime}
			 )
		 </foreach>
			on DUPLICATE key update 
			name = VALUES(name),
			intro = VALUES(intro),
			cover_url = VALUES(cover_url),
			sort = VALUES(sort),
			status = VALUES(status),
			create_time = VALUES(create_time)
	</insert>

	<!--多条件修改-->
	<update id="updateByParam" parameterType="org.example.rhizome_networkbackend.entity.query.ForumCategoryQuery">
		 UPDATE forum_category f
 		 <set> 
			<if test="bean.name != null">
				 name = #{bean.name},
			</if>
			<if test="bean.intro != null">
				 intro = #{bean.intro},
			</if>
			<if test="bean.coverUrl != null">
				 cover_url = #{bean.coverUrl},
			</if>
			<if test="bean.sort != null">
				 sort = #{bean.sort},
			</if>
			<if test="bean.status != null">
				 status = #{bean.status},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 <include refid="query_condition" />
	</update>

	<!--多条件删除-->
	<delete id="deleteByParam">
		 delete f from forum_category f
 		 <include refid="query_condition" />
	</delete>

	<!-- 根据CategoryId修改-->
	<update id="updateByCategoryId" parameterType="org.example.rhizome_networkbackend.entity.po.ForumCategory">
		 UPDATE forum_category
 		 <set> 
			<if test="bean.name != null">
				 name = #{bean.name},
			</if>
			<if test="bean.intro != null">
				 intro = #{bean.intro},
			</if>
			<if test="bean.coverUrl != null">
				 cover_url = #{bean.coverUrl},
			</if>
			<if test="bean.sort != null">
				 sort = #{bean.sort},
			</if>
			<if test="bean.status != null">
				 status = #{bean.status},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 where category_id=#{categoryId}
	</update>

	<!-- 根据CategoryId删除-->
	<delete id="deleteByCategoryId">
		delete from forum_category where category_id=#{categoryId}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectByCategoryId" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from forum_category f where category_id=#{categoryId}
	</select>

</mapper>