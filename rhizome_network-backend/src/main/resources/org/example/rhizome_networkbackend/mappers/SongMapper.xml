<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.rhizome_networkbackend.mappers.SongMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="org.example.rhizome_networkbackend.entity.po.Song">
		<!--歌曲ID-->
		<id column="song_id" property="songId"  />
		<!--歌曲唯一标识-->
		<result column="songKey" property="songkey"  />
		<!--歌曲名-->
		<result column="title" property="title"  />
		<!--艺术家-->
		<result column="artist" property="artist"  />
		<!--总播放数-->
		<result column="play_count" property="playCount"  />
		<!--评论数-->
		<result column="comment_count" property="commentCount"  />
		<!--创建时间-->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 s.song_id,s.songKey,s.title,s.artist,s.play_count,
		 s.comment_count,s.create_time
	</sql>

	<sql id="base_condition_filed">
			<if test="query.songId != null">
				 and  s.song_id = #{query.songId}
			</if>
			<if test="query.songkey != null and query.songkey!=''">
				 and  s.songKey = #{query.songkey}
			</if>
			<if test="query.title != null and query.title!=''">
				 and  s.title = #{query.title}
			</if>
			<if test="query.artist != null and query.artist!=''">
				 and  s.artist = #{query.artist}
			</if>
			<if test="query.playCount != null">
				 and  s.play_count = #{query.playCount}
			</if>
			<if test="query.commentCount != null">
				 and  s.comment_count = #{query.commentCount}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  s.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.songkeyFuzzy!= null  and query.songkeyFuzzy!=''">
				 and  s.songKey like concat('%', #{query.songkeyFuzzy}, '%')
			</if>
			<if test="query.titleFuzzy!= null  and query.titleFuzzy!=''">
				 and  s.title like concat('%', #{query.titleFuzzy}, '%')
			</if>
			<if test="query.artistFuzzy!= null  and query.artistFuzzy!=''">
				 and  s.artist like concat('%', #{query.artistFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  s.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  s.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM song s <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM song s <include refid="query_condition" />
	</select>

	<!-- 插入 （匹配有值的字段）-->
	<insert id="insert" parameterType="org.example.rhizome_networkbackend.entity.po.Song">
		<selectKey keyProperty="bean.songId" resultType="Long" order="AFTER">
			SELECT LAST_INSERT_ID()
		</selectKey>
		 INSERT INTO song
		 <trim prefix="(" suffix=")" suffixOverrides="," >
			<if test="bean.songkey != null">
				 songKey,
			</if>
			<if test="bean.title != null">
				 title,
			</if>
			<if test="bean.artist != null">
				 artist,
			</if>
			<if test="bean.playCount != null">
				 play_count,
			</if>
			<if test="bean.commentCount != null">
				 comment_count,
			</if>
			<if test="bean.createTime != null">
				 create_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.songkey!=null">
				 #{bean.songkey},
			</if>
			<if test="bean.title!=null">
				 #{bean.title},
			</if>
			<if test="bean.artist!=null">
				 #{bean.artist},
			</if>
			<if test="bean.playCount!=null">
				 #{bean.playCount},
			</if>
			<if test="bean.commentCount!=null">
				 #{bean.commentCount},
			</if>
			<if test="bean.createTime!=null">
				 #{bean.createTime},
			</if>
		 </trim>
	</insert>

	<!-- 插入或者更新 （匹配有值的字段）-->
	<insert id="insertOrUpdate" parameterType="org.example.rhizome_networkbackend.entity.po.Song">
		 INSERT INTO song
		 <trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.songId != null">
				 song_id,
			</if>
			<if test="bean.songkey != null">
				 songKey,
			</if>
			<if test="bean.title != null">
				 title,
			</if>
			<if test="bean.artist != null">
				 artist,
			</if>
			<if test="bean.playCount != null">
				 play_count,
			</if>
			<if test="bean.commentCount != null">
				 comment_count,
			</if>
			<if test="bean.createTime != null">
				 create_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.songId!=null">
				 #{bean.songId},
			</if>
			<if test="bean.songkey!=null">
				 #{bean.songkey},
			</if>
			<if test="bean.title!=null">
				 #{bean.title},
			</if>
			<if test="bean.artist!=null">
				 #{bean.artist},
			</if>
			<if test="bean.playCount!=null">
				 #{bean.playCount},
			</if>
			<if test="bean.commentCount!=null">
				 #{bean.commentCount},
			</if>
			<if test="bean.createTime!=null">
				 #{bean.createTime},
			</if>
		 </trim>
		 on DUPLICATE key update 
		 <trim prefix="" suffix="" suffixOverrides=",">
			<if test="bean.songkey!=null">
				 songKey = VALUES(songKey),
			</if>
			<if test="bean.title!=null">
				 title = VALUES(title),
			</if>
			<if test="bean.artist!=null">
				 artist = VALUES(artist),
			</if>
			<if test="bean.playCount!=null">
				 play_count = VALUES(play_count),
			</if>
			<if test="bean.commentCount!=null">
				 comment_count = VALUES(comment_count),
			</if>
			<if test="bean.createTime!=null">
				 create_time = VALUES(create_time),
			</if>
		 </trim>
	</insert>

	<!-- 添加 （批量插入）-->
	<insert id="insertBatch" parameterType="org.example.rhizome_networkbackend.entity.po.Song" useGeneratedKeys="true" keyProperty="songId">
		 INSERT INTO song(
			 songKey,
			 title,
			 artist,
			 play_count,
			 comment_count,
			 create_time
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.songkey},
				 #{item.title},
				 #{item.artist},
				 #{item.playCount},
				 #{item.commentCount},
				 #{item.createTime}
			 )
		 </foreach>
	</insert>

	<!-- 批量新增修改 （批量插入）-->
	<insert id="insertOrUpdateBatch" parameterType="org.example.rhizome_networkbackend.entity.po.Song">
		 INSERT INTO song(
			 songKey,
			 title,
			 artist,
			 play_count,
			 comment_count,
			 create_time
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.songkey},
				 #{item.title},
				 #{item.artist},
				 #{item.playCount},
				 #{item.commentCount},
				 #{item.createTime}
			 )
		 </foreach>
			on DUPLICATE key update 
			songKey = VALUES(songKey),
			title = VALUES(title),
			artist = VALUES(artist),
			play_count = VALUES(play_count),
			comment_count = VALUES(comment_count),
			create_time = VALUES(create_time)
	</insert>

	<!--多条件修改-->
	<update id="updateByParam" parameterType="org.example.rhizome_networkbackend.entity.query.SongQuery">
		 UPDATE song s
 		 <set> 
			<if test="bean.songkey != null">
				 songKey = #{bean.songkey},
			</if>
			<if test="bean.title != null">
				 title = #{bean.title},
			</if>
			<if test="bean.artist != null">
				 artist = #{bean.artist},
			</if>
			<if test="bean.playCount != null">
				 play_count = #{bean.playCount},
			</if>
			<if test="bean.commentCount != null">
				 comment_count = #{bean.commentCount},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 <include refid="query_condition" />
	</update>

	<!--多条件删除-->
	<delete id="deleteByParam">
		 delete s from song s
 		 <include refid="query_condition" />
	</delete>

	<!-- 根据SongId修改-->
	<update id="updateBySongId" parameterType="org.example.rhizome_networkbackend.entity.po.Song">
		 UPDATE song
 		 <set> 
			<if test="bean.songkey != null">
				 songKey = #{bean.songkey},
			</if>
			<if test="bean.title != null">
				 title = #{bean.title},
			</if>
			<if test="bean.artist != null">
				 artist = #{bean.artist},
			</if>
			<if test="bean.playCount != null">
				 play_count = #{bean.playCount},
			</if>
			<if test="bean.commentCount != null">
				 comment_count = #{bean.commentCount},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 where song_id=#{songId}
	</update>

	<!-- 根据SongId删除-->
	<delete id="deleteBySongId">
		delete from song where song_id=#{songId}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectBySongId" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from song s where song_id=#{songId}
	</select>

	<!-- 根据Songkey修改-->
	<update id="updateBySongkey" parameterType="org.example.rhizome_networkbackend.entity.po.Song">
		 UPDATE song
 		 <set> 
			<if test="bean.title != null">
				 title = #{bean.title},
			</if>
			<if test="bean.artist != null">
				 artist = #{bean.artist},
			</if>
			<if test="bean.playCount != null">
				 play_count = #{bean.playCount},
			</if>
			<if test="bean.commentCount != null">
				 comment_count = #{bean.commentCount},
			</if>
			<if test="bean.createTime != null">
				 create_time = #{bean.createTime},
			</if>
 		 </set>
 		 where songKey=#{songkey}
	</update>

	<!-- 根据Songkey删除-->
	<delete id="deleteBySongkey">
		delete from song where songKey=#{songkey}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectBySongkey" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from song s where songKey=#{songkey}
	</select>

</mapper>