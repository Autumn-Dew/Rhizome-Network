<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.rhizome_networkbackend.mappers.CommentMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="org.example.rhizome_networkbackend.entity.po.Comment">
		<!--评论ID-->
		<id column="comment_id" property="commentId"  />
		<!--歌曲标识-->
		<result column="songKey" property="songkey"  />
		<!--用户ID-->
		<result column="user_id" property="userId"  />
		<!--评论内容-->
		<result column="content" property="content"  />
		<!--点赞数-->
		<result column="like_count" property="likeCount"  />
		<!--父评论ID，0为一级-->
		<result column="parent_id" property="parentId"  />
		<!--0正常 1删除-->
		<result column="status" property="status"  />
		<!--发布时间-->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 c.comment_id,c.songKey,c.user_id,c.content,c.like_count,
		 c.parent_id,c.status,c.create_time
	</sql>

	<sql id="base_condition_filed">
			<if test="query.commentId != null">
				 and  c.comment_id = #{query.commentId}
			</if>
			<if test="query.songkey != null and query.songkey!=''">
				 and  c.songKey = #{query.songkey}
			</if>
			<if test="query.userId != null">
				 and  c.user_id = #{query.userId}
			</if>
			<if test="query.content != null and query.content!=''">
				 and  c.content = #{query.content}
			</if>
			<if test="query.likeCount != null">
				 and  c.like_count = #{query.likeCount}
			</if>
			<if test="query.parentId != null">
				 and  c.parent_id = #{query.parentId}
			</if>
			<if test="query.status != null">
				 and  c.status = #{query.status}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  c.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.songkeyFuzzy!= null  and query.songkeyFuzzy!=''">
				 and  c.songKey like concat('%', #{query.songkeyFuzzy}, '%')
			</if>
			<if test="query.contentFuzzy!= null  and query.contentFuzzy!=''">
				 and  c.content like concat('%', #{query.contentFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  c.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  c.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM comment c <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM comment c <include refid="query_condition" />
	</select>

	<!-- 插入 （匹配有值的字段）-->
	<insert id="insert" parameterType="org.example.rhizome_networkbackend.entity.po.Comment">
		<selectKey keyProperty="bean.commentId" resultType="Long" order="AFTER">
			SELECT LAST_INSERT_ID()
		</selectKey>
		 INSERT INTO comment
		 <trim prefix="(" suffix=")" suffixOverrides="," >
			<if test="bean.songkey != null">
				 songKey,
			</if>
			<if test="bean.userId != null">
				 user_id,
			</if>
			<if test="bean.content != null">
				 content,
			</if>
			<if test="bean.likeCount != null">
				 like_count,
			</if>
			<if test="bean.parentId != null">
				 parent_id,
			</if>
			<if test="bean.status != null">
				 status,
			</if>
			<if test="bean.createTime != null">
				 create_time,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.songkey!=null">
				 #{bean.songkey},
			</if>
			<if test="bean.userId!=null">
				 #{bean.userId},
			</if>
			<if test="bean.content!=null">
				 #{bean.content},
			</if>
			<if test="bean.likeCount!=null">
				 #{bean.likeCount},
			</if>
			<if test="bean.parentId!=null">
				 #{bean.parentId},
			</if>
			<if test="bean.status!=null">
				 #{bean.status},
			</if>
			<if test="bean.createTime!=null">
				 #{bean.createTime},
			</if>
		 </trim>
	</insert>

	<!-- 插入或者更新 （匹配有值的字段）-->
	<insert id="insertOrUpdate" parameterType="org.example.rhizome_networkbackend.entity.po.Comment">
		 INSERT INTO comment
		 <trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.commentId != null">
