			</if>
		 </trim>
	</insert>

	<!-- 添加 （批量插入）-->
	<insert id="insertBatch" parameterType="org.example.rhizome_networkbackend.entity.po.Comment" useGeneratedKeys="true" keyProperty="commentId">
		 INSERT INTO comment(
			 songKey,
			 user_id,
			 content,
			 like_count,
			 parent_id,
			 status,
			 create_time
		 )values
		 <foreach collection="list" item="item" separator=",">
