		 </foreach>
			on DUPLICATE key update 
			playlist_id = VALUES(playlist_id),
			songKey = VALUES(songKey),
			add_time = VALUES(add_time)
	</insert>

	<!--多条件修改-->
	<update id="updateByParam" parameterType="org.example.rhizome_networkbackend.entity.query.PlaylistSongQuery">
		 UPDATE playlist_song p
 		 <set> 
			<if test="bean.playlistId != null">
				 playlist_id = #{bean.playlistId},
			</if>
			<if test="bean.songkey != null">
				 songKey = #{bean.songkey},
			</if>
			<if test="bean.addTime != null">
				 add_time = #{bean.addTime},
			</if>
 		 </set>
 		 <include refid="query_condition" />
	</update>

	<!--多条件删除-->
	<delete id="deleteByParam">
		 delete p from playlist_song p
 		 <include refid="query_condition" />
	</delete>

	<!-- 根据Id修改-->
	<update id="updateById" parameterType="org.example.rhizome_networkbackend.entity.po.PlaylistSong">
		 UPDATE playlist_song
 		 <set> 
			<if test="bean.playlistId != null">
				 playlist_id = #{bean.playlistId},
			</if>
			<if test="bean.songkey != null">
				 songKey = #{bean.songkey},
			</if>
			<if test="bean.addTime != null">
